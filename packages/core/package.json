{
  "name": "@bkalafat/markhome-core",
  "version": "0.1.0",
  "description": "Parser, AST types, and validation for MarkHome diagrams.",
  "type": "module",
  "license": "MIT",
  "author": "Burak Kalafat",
  "homepage": "https://github.com/bkalafat/markhome#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bkalafat/markhome.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/bkalafat/markhome/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "markhome",
    "parser",
    "ast",
    "diagram",
    "floorplan"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  }
}
