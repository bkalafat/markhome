{
  "name": "@markhome/cli",
  "version": "0.1.0",
  "description": "Command-line renderer for MarkHome diagrams.",
  "type": "module",
  "bin": {
    "markhome": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "markhome": "workspace:*"
  },
  "license": "MIT"
}
